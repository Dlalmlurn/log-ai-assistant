# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_RAW_TOPIC=raw_logs
KAFKA_PARSED_TOPIC=parsed_logs
KAFKA_ALERT_TOPIC=alert_events
KAFKA_AI_TOPIC=ai_reports
KAFKA_METRICS_TOPIC=system_metrics

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_LOG_INDEX=security-logs
ELASTICSEARCH_ALERT_INDEX=security-alerts
ELASTICSEARCH_AI_INDEX=ai-reports
ELASTICSEARCH_DAILY_INDEX=daily-reports
ELASTICSEARCH_BASELINE_INDEX=user-baselines

# Flink
FLINK_DASHBOARD_URL=http://localhost:8081

# DashScope / Qwen
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# log-generator path (mentor provided)
GENERATOR_SCRIPT=log-generator/gen_vpn_logs.py
GENERATOR_JSONL=log-generator/vpn_output/vpn_logs.jsonl
GENERATOR_SYSLOG=log-generator/vpn_output/vpn_logs.log

# Rule thresholds
THRESHOLD_IP_FAIL_5M=8
THRESHOLD_USER_FAIL_5M=5
THRESHOLD_API_CALL_1M=80
THRESHOLD_SENSITIVE_5M=5
THRESHOLD_MULTI_USER_FAIL_IP_5M=4

WORK_HOUR_START=9
WORK_HOUR_END=18
