# Docker-first runtime
COMPOSE_PROJECT_NAME=log-ai-assistant

# Kafka
# Container-to-container address used by Filebeat, Flink, backend, tester.
KAFKA_BOOTSTRAP_SERVERS_DOCKER=kafka:9092
# Optional host address for local debugging tools outside Docker.
KAFKA_BOOTSTRAP_SERVERS_HOST=localhost:9092
KAFKA_HOST_PORT=9092
KAFKA_CONTROLLER_HOST_PORT=9093
KAFKA_TOPIC_PARTITIONS=3
KAFKA_RAW_TOPIC=raw_logs
KAFKA_PARSED_TOPIC=parsed_logs
KAFKA_ALERT_TOPIC=alert_events
KAFKA_AI_TOPIC=ai_reports
KAFKA_METRICS_TOPIC=system_metrics

# ClickHouse
# Container-to-container address used by backend and future Flink sinks.
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DATABASE=log_ai
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
# Host ports for browser or optional local tools.
CLICKHOUSE_HTTP_HOST=localhost
CLICKHOUSE_HTTP_HOST_PORT=8123
CLICKHOUSE_NATIVE_HOST=localhost
CLICKHOUSE_NATIVE_HOST_PORT=9000

# FastAPI backend
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_HOST_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173

# React frontend
FRONTEND_HOST_PORT=5173
VITE_API_BASE_URL=http://localhost:8000

# Flink
# Container URL is used by backend health checks; host URL is for browsers.
FLINK_DASHBOARD_URL_DOCKER=http://flink-jobmanager:8081
FLINK_DASHBOARD_HOST_URL=http://localhost:8081
FLINK_DASHBOARD_HOST_PORT=8081

# Filebeat
FILEBEAT_LOG_PATH=/var/log/app/vpn_logs.log

# AI API placeholders
DASHSCOPE_API_KEY_DOCKER=
DASHSCOPE_MODEL=qwen-plus
OPENAI_API_KEY=

# Default small continuous generator for daily development.
LOG_GENERATOR_OUTPUT=/var/log/app/vpn_logs.log
LOG_GENERATOR_INTERVAL_SECONDS=5
LOG_GENERATOR_BATCH_SIZE=3
LOG_GENERATOR_SEED=42

# Higher-volume generator used only with: docker compose --profile scale up --build
LOG_GENERATOR_SCALE_INTERVAL_SECONDS=1
LOG_GENERATOR_SCALE_BATCH_SIZE=50
LOG_GENERATOR_SCALE_SEED=4242
