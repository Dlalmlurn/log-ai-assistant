# Python cache / build
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
dist/
build/
*.egg-info/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE / OS files
.idea/
.vscode/
.DS_Store
Thumbs.db

# Local env / secrets
.env
.env.local
.streamlit/secrets.toml

# Runtime logs / data outputs
logs/*
!logs/.gitkeep
data/*
!data/.gitkeep

# Generated log-generator outputs
log-generator/vpn_output/*.csv
log-generator/vpn_output/*.jsonl
log-generator/vpn_output/*.log

# Optional local runtime artifacts
*.pid
*.out
*.err

# Codex development loop state
.codex-loop/
